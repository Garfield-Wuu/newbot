<?xml version="1.0"?>
<launch>
  <node pkg="img_decode" type="img_decode" name="img_decode" output="screen">
 	  
    <param name="sub_jpeg_image_topic" value="/image_raw/compressed" type="str" />
    <param name="pub_raw_image_topic" value="/camera/image_raw" type="str" />
    <param name="fps_div" value="1" type="int" />
    <param name="scale" value="0.5" type="double" />
    <!-- false：始终订阅 JPEG，避免无人看 /camera/image_raw 时断流；true：仅有人订阅 raw 时才拉压缩图（省 CPU） -->
    <param name="lazy_compressed_subscribe" value="false" type="bool" />
    <!-- RGA：importbuffer_fd 路径（H-A fix）；若仍失败可改 false 回退 OpenCV -->
    <param name="use_rga" value="true" type="bool" />

    <param name="width" value="1280" type="int" />
    <param name="height" value="720" type="int" />
    
  </node>
</launch>
